{
  "$schema": "htt*s://openapi.vercel.sh/vercel.json"*
  "cleanUrls": true,
  "redirects*: [
    { "source": "/index.html",*"destination": "/", "permanent": t*ue },
    { "source": "/product.ht*l", "destination": "/", "permanent*: true },
    { "source": "/trendi*g-products", "destination": "/top-*rending-products/", "permanent": t*ue },
    { "source": "/winning-pr*ducts", "destination": "/top-trend*ng-products/", "permanent": true }*
    { "source": "/product-researc*", "destination": "/", "permanent"* true },
    { "source": "/trendin*-today", "destination": "/top-tren*ing-products/", "permanent": true *,
    { "source": "/trending-today*", "destination": "/top-trending-p*oducts/", "permanent": true },
   *{ "source": "/trending-this-week",*"destination": "/trending-this-month/", "permanent": true },
    { "source": "/trending-this-week/", "destination": "/trending-this-month/", "permanent": true },
    { "source": "/tiktok-products", "destination": "/viral-tiktok-products/", "permanent": true },
    { "source": "/tiktok-products/", "destination": "/viral-tiktok-products/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/router?path=$1"
    }
  ]
}
